# Tor configuration for ft_onion hidden service

# Define the directory where Tor will store the hidden service keys and hostname (.onion address)
HiddenServiceDir /var/lib/tor/hidden_service/

# Forward Tor's port 80 (web) to local Nginx on port 80
HiddenServicePort 80 127.0.0.1:80

# Forward Tor's port 4242 (SSH) to local SSH daemon on port 4242
HiddenServicePort 4242 127.0.0.1:4242